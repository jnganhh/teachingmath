<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>MCR3U – Vertex of a Quadratic (Standard Form)</title>
<meta name="viewport" content="width=device-width,initial-scale=1">
<style>
  body{
    font-family:system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;
    margin:0;
    background:#0f172a;
    color:#e5e7eb;
  }
  .app{
    max-width:900px;
    margin:0 auto;
    padding:16px;
  }
  h1{
    font-size:1.6rem;
    margin:0 0 8px;
    text-align:center;
    color:#facc15;
  }
  h2{
    font-size:1.1rem;
    margin:12px 0 6px;
    color:#a5b4fc;
  }
  .card{
    background:#020617;
    border-radius:12px;
    box-shadow:0 18px 40px rgba(15,23,42,0.9);
    padding:16px;
    margin-bottom:14px;
    border:1px solid #1e293b;
  }
  label{
    font-size:0.9rem;
  }
  input[type="text"], select{
    padding:6px 8px;
    border-radius:6px;
    border:1px solid #4b5563;
    background:#020617;
    color:#e5e7eb;
    font-size:0.9rem;
    width:100%;
    box-sizing:border-box;
  }
  input[type="text"]:focus, select:focus{
    outline:none;
    border-color:#6366f1;
    box-shadow:0 0 0 1px #6366f1;
  }
  .row{
    display:flex;
    flex-wrap:wrap;
    gap:10px;
  }
  .col{
    flex:1 1 160px;
  }
  button{
    border:none;
    border-radius:999px;
    padding:8px 16px;
    font-size:0.95rem;
    cursor:pointer;
    background:linear-gradient(135deg,#4f46e5,#7c3aed);
    color:white;
    display:inline-flex;
    align-items:center;
    gap:6px;
  }
  button[disabled]{
    opacity:0.5;
    cursor:not-allowed;
  }
  .btn-secondary{
    background:#111827;
    border:1px solid #374151;
  }
  .pill{
    display:inline-block;
    padding:2px 8px;
    border-radius:999px;
    font-size:0.75rem;
    background:#111827;
    border:1px solid #374151;
    color:#9ca3af;
    margin-right:4px;
  }
  .status-bar{
    display:flex;
    flex-wrap:wrap;
    gap:8px;
    align-items:center;
    justify-content:space-between;
    font-size:0.85rem;
  }
  .status-group{
    display:flex;
    flex-wrap:wrap;
    gap:6px;
    align-items:center;
  }
  .status-chip{
    padding:4px 8px;
    border-radius:999px;
    background:#111827;
    border:1px solid #374151;
  }
  .status-chip strong{
    color:#fbbf24;
  }
  .question-area{
    font-size:1rem;
    margin:10px 0;
  }
  .equation{
    font-family:"SF Mono","Consolas","Menlo",monospace;
    font-size:1.05rem;
    background:#020617;
    padding:6px 10px;
    border-radius:6px;
    border:1px solid #1f2937;
    display:inline-block;
  }
  .options{
    margin-top:8px;
  }
  .option{
    margin:4px 0;
    padding:6px 8px;
    border-radius:6px;
    border:1px solid #1f2937;
    background:#020617;
  }
  .option input{
    margin-right:6px;
  }
  .answer-inputs{
    margin-top:8px;
    display:flex;
    flex-wrap:wrap;
    gap:8px;
    align-items:center;
  }
  .answer-inputs span{
    font-size:0.95rem;
  }
  .feedback{
    margin-top:8px;
    padding:8px;
    border-radius:8px;
    font-size:0.9rem;
  }
  .feedback.correct{
    background:#022c22;
    border:1px solid #047857;
    color:#bbf7d0;
  }
  .feedback.incorrect{
    background:#3f1d2b;
    border:1px solid #f97373;
    color:#fecaca;
  }
  .ai-hint{
    margin-top:6px;
    padding:8px;
    border-radius:8px;
    background:#020617;
    border:1px dashed #4b5563;
    font-size:0.88rem;
  }
  .scoreboard{
    font-size:0.86rem;
    margin-top:8px;
  }
  .scoreboard table{
    width:100%;
    border-collapse:collapse;
  }
  .scoreboard th,.scoreboard td{
    border:1px solid #1f2937;
    padding:4px 6px;
    text-align:left;
  }
  .scoreboard th{
    background:#020617;
  }
  .tagline{
    font-size:0.8rem;
    text-align:center;
    color:#9ca3af;
    margin-top:2px;
  }
  @media (max-width:600px){
    .status-bar{
      flex-direction:column;
      align-items:flex-start;
    }
  }
</style>
</head>
<body>
<div class="app">
  <h1>MCR3U – Vertex Practice</h1>
  <div class="tagline">Practice finding the vertex of \(y=ax^2+bx+c\) before your next test.</div>

  <!-- Student setup -->
  <div class="card" id="setupCard">
    <h2>1. Student & settings</h2>
    <div class="row">
      <div class="col">
        <label>Student name</label>
        <input type="text" id="studentName" placeholder="e.g. Alex Wong">
      </div>
      <div class="col">
        <label>Class</label>
        <input type="text" id="studentClass" placeholder="e.g. MCR3U-1">
      </div>
    </div>
    <div class="row" style="margin-top:10px;">
      <div class="col">
        <label>Difficulty</label>
        <select id="difficulty">
          <option value="easy">Easy (nice integers)</option>
          <option value="medium" selected>Medium (integer vertex)</option>
          <option value="hard">Hard (fractional vertex)</option>
        </select>
      </div>
      <div class="col">
        <label>Mode</label>
        <select id="mode">
          <option value="mc">Multiple choice</option>
          <option value="sa">Short answer</option>
        </select>
      </div>
      <div class="col">
        <label>Number of questions</label>
        <select id="numQuestions">
          <option value="5">5</option>
          <option value="8" selected>8</option>
          <option value="10">10</option>
        </select>
      </div>
    </div>
    <div style="margin-top:12px;display:flex;gap:8px;align-items:center;">
      <button id="startBtn">
        <span>▶</span><span>Start practice</span>
      </button>
      <span style="font-size:0.8rem;color:#9ca3af;">
        Timer starts when you begin. You can pause thinking, but not the clock!
      </span>
    </div>
  </div>

  <!-- Live quiz area -->
  <div class="card" id="quizCard" style="display:none;">
    <div class="status-bar">
      <div class="status-group">
        <div class="status-chip">
          <strong id="labelName">Name</strong>:
          <span id="displayName"></span>
        </div>
        <div class="status-chip">
          <strong>Class</strong>:
          <span id="displayClass"></span>
        </div>
        <div class="status-chip">
          <strong>Q</strong> <span id="qNumber">1</span>/<span id="qTotal">8</span>
        </div>
      </div>
      <div class="status-group">
        <div class="status-chip">
          ⏱ <strong>Time</strong>:
          <span id="timeDisplay">0:00</span>
        </div>
        <div class="status-chip">
          ✅ <strong>Score</strong>:
          <span id="scoreDisplay">0</span>
        </div>
      </div>
    </div>

    <hr style="border:none;border-top:1px solid #1f2937;margin:10px 0;">

    <div class="question-area">
      <div id="questionPrompt"></div>
      <div class="equation" id="equationText"></div>

      <div id="mcArea" class="options" style="display:none;"></div>

      <div id="saArea" class="answer-inputs" style="display:none;">
        <span>Vertex:</span>
        <span>(</span>
        <input type="text" id="inputHx" style="width:60px;" placeholder="h">
        <span>,</span>
        <input type="text" id="inputKy" style="width:60px;" placeholder="k">
        <span>)</span>
      </div>
    </div>

    <div style="margin-top:10px;display:flex;gap:8px;flex-wrap:wrap;">
      <button id="submitBtn">
        <span>✓</span><span>Submit answer</span>
      </button>
      <button id="nextBtn" class="btn-secondary" style="display:none;">
        Next question
      </button>
      <button id="aiHintBtn" class="btn-secondary" type="button">
        💡 AI hint
      </button>
    </div>

    <div id="feedback" class="feedback" style="display:none;"></div>
    <div id="aiHint" class="ai-hint" style="display:none;"></div>
  </div>

  <!-- Summary -->
  <div class="card" id="summaryCard" style="display:none;">
    <h2>Session summary</h2>
    <p id="summaryText" style="font-size:0.9rem;margin-top:4px;"></p>
    <div id="smartComment" class="ai-hint"></div>
    <div class="scoreboard" id="scoreboardContainer" style="display:none;">
      <h2>Personal best on this device</h2>
      <table id="scoreTable">
        <thead>
          <tr>
            <th>When</th>
            <th>Name</th>
            <th>Class</th>
            <th>Difficulty</th>
            <th>Mode</th>
            <th>Score</th>
            <th>Time</th>
          </tr>
        </thead>
        <tbody></tbody>
      </table>
      <p style="margin-top:4px;color:#9ca3af;font-size:0.8rem;">
        Scores are saved in this browser only (using localStorage).
      </p>
    </div>
    <div style="margin-top:10px;display:flex;gap:8px;flex-wrap:wrap;">
      <button id="restartBtn">Try again with new questions</button>
      <button id="resetScoresBtn" class="btn-secondary">Clear saved scores</button>
    </div>
  </div>
</div>

<script>
(function(){
  // ---------- Utility ----------
  function randInt(min,max){return Math.floor(Math.random()*(max-min+1))+min;}
  function formatTime(seconds){
    const m=Math.floor(seconds/60);
    const s=seconds%60;
    return m+":"+(s<10?"0"+s:s);
  }
  function shuffle(arr){
    for(let i=arr.length-1;i>0;i--){
      const j=Math.floor(Math.random()*(i+1));
      [arr[i],arr[j]]=[arr[j],arr[i]];
    }
    return arr;
  }
  function approxEqual(a,b,tol){
    return Math.abs(a-b)<=tol;
  }

  // ---------- State ----------
  let questions=[];
  let currentIndex=0;
  let score=0;
  let timer=null;
  let elapsed=0;
  let mode="mc";
  let difficulty="medium";
  let numQuestions=8;
  let currentQuestion=null;

  // ---------- Generate questions ----------
  function generateQuestions(level,count){
    const qs=[];
    for(let i=0;i<count;i++){
      let a,b,c,h,k;
      if(level==="easy"){
        // a=1, vertex with small integers, expand to standard form
        h=randInt(-4,4);
        k=randInt(-5,5);
        a=1;
        // y=(x-h)^2+k => y=x^2-2hx+h^2+k
        b=-2*h;
        c=h*h+k;
      }else if(level==="medium"){
        // a is -2,-1,1,2, vertex integer
        const aChoices=[-2,-1,1,2];
        a=aChoices[randInt(0,aChoices.length-1)];
        h=randInt(-5,5);
        k=randInt(-6,6);
        // expand y=a(x-h)^2+k
        // y=a(x^2-2hx+h^2)+k = ax^2+(-2ah)x + (ah^2+k)
        b=-2*a*h;
        c=a*h*h+k;
      }else{
        // hard: random a,b,c, vertex may be fractional (ensure a≠0)
        a=randInt(-3,3); if(a===0)a=1;
        b=randInt(-8,8);
        c=randInt(-10,10);
        // true vertex
        h=-b/(2*a);
        k=a*h*h+b*h+c;
      }

      const eqString = "y = " + coefToText(a,"x²")
                      + termToText(b,"x")
                      + constantToText(c);

      const question={
        a:a,b:b,c:c,
        h:h,k:k,
        text:eqString,
        id:"Q"+(i+1)
      };

      if(mode==="mc"){
        question.options=makeOptionsForVertex(h,k);
      }
      qs.push(question);
    }
    return qs;
  }

  function coefToText(coef,term){
    if(coef===1) return term;
    if(coef===-1) return "-"+term;
    return coef+term;
  }
  function termToText(coef,term){
    if(coef===0) return "";
    if(coef>0) return " + "+(coef===1?term:coef+term);
    return " - "+(Math.abs(coef)===1?term:Math.abs(coef)+term);
  }
  function constantToText(c){
    if(c===0) return "";
    if(c>0) return " + "+c;
    return " - "+Math.abs(c);
  }

  function makeOptionsForVertex(h,k){
    // correct vertex
    const opts=[[h,k]];
    // generate 3 distractors
    const deltas=[[-1,0],[1,0],[0,1],[0,-1],[2,0],[0,2],[-2,0],[0,-2]];
    shuffle(deltas);
    let i=0;
    while(opts.length<4 && i<deltas.length){
      const dh=deltas[i][0], dk=deltas[i][1];
      const cand=[roundNice(h+dh),roundNice(k+dk)];
      if(!opts.some(v=>approxEqual(v[0],cand[0],0.001)&&approxEqual(v[1],cand[1],0.001))){
        opts.push(cand);
      }
      i++;
    }
    // if still less than 4 (in some weird cases), add random integers
    while(opts.length<4){
      const cand=[randInt(-5,5),randInt(-6,6)];
      if(!opts.some(v=>v[0]===cand[0]&&v[1]===cand[1])){
        opts.push(cand);
      }
    }
    return shuffle(opts);
  }

  function roundNice(x){
    return Math.round(x*10)/10;
  }

  // ---------- Rendering ----------
  const setupCard=document.getElementById("setupCard");
  const quizCard=document.getElementById("quizCard");
  const summaryCard=document.getElementById("summaryCard");
  const startBtn=document.getElementById("startBtn");
  const restartBtn=document.getElementById("restartBtn");
  const resetScoresBtn=document.getElementById("resetScoresBtn");

  const studentNameInput=document.getElementById("studentName");
  const studentClassInput=document.getElementById("studentClass");
  const difficultySelect=document.getElementById("difficulty");
  const modeSelect=document.getElementById("mode");
  const numQuestionsSelect=document.getElementById("numQuestions");

  const displayName=document.getElementById("displayName");
  const displayClass=document.getElementById("displayClass");
  const timeDisplay=document.getElementById("timeDisplay");
  const scoreDisplay=document.getElementById("scoreDisplay");
  const qNumber=document.getElementById("qNumber");
  const qTotal=document.getElementById("qTotal");

  const questionPrompt=document.getElementById("questionPrompt");
  const equationText=document.getElementById("equationText");
  const mcArea=document.getElementById("mcArea");
  const saArea=document.getElementById("saArea");
  const inputHx=document.getElementById("inputHx");
  const inputKy=document.getElementById("inputKy");
  const submitBtn=document.getElementById("submitBtn");
  const nextBtn=document.getElementById("nextBtn");
  const feedbackDiv=document.getElementById("feedback");
  const aiHintBtn=document.getElementById("aiHintBtn");
  const aiHintDiv=document.getElementById("aiHint");

  const summaryText=document.getElementById("summaryText");
  const smartComment=document.getElementById("smartComment");
  const scoreboardContainer=document.getElementById("scoreboardContainer");
  const scoreTableBody=document.querySelector("#scoreTable tbody");

  function showQuestion(){
    currentQuestion=questions[currentIndex];
    qNumber.textContent=(currentIndex+1);
    qTotal.textContent=questions.length;
    scoreDisplay.textContent=score;

    questionPrompt.textContent="Find the vertex of the quadratic function below.";
    equationText.textContent=currentQuestion.text;

    feedbackDiv.style.display="none";
    aiHintDiv.style.display="none";
    submitBtn.disabled=false;
    nextBtn.style.display="none";

    if(mode==="mc"){
      mcArea.style.display="block";
      saArea.style.display="none";
      renderOptions();
    }else{
      mcArea.style.display="none";
      saArea.style.display="flex";
      inputHx.value="";
      inputKy.value="";
      inputHx.focus();
    }
  }

  function renderOptions(){
    mcArea.innerHTML="";
    currentQuestion.options.forEach((v,i)=>{
      const id="opt"+i;
      const opt=document.createElement("label");
      opt.className="option";
      opt.innerHTML='<input type="radio" name="vertex" id="'+id+'" value="'+v[0]+","+v[1]+'">('+
        v[0]+", "+v[1]+")";
      mcArea.appendChild(opt);
    });
  }

  // ---------- Timer ----------
  function startTimer(){
    if(timer)clearInterval(timer);
    elapsed=0;
    timeDisplay.textContent="0:00";
    timer=setInterval(()=>{
      elapsed++;
      timeDisplay.textContent=formatTime(elapsed);
    },1000);
  }
  function stopTimer(){
    if(timer)clearInterval(timer);
    timer=null;
  }

  // ---------- Answer checking ----------
  function parseNumberInput(str){
    str=str.trim();
    if(str==="")return null;
    // allow fractions
    if(str.includes("/")){
      const parts=str.split("/");
      if(parts.length===2){
        const n=parseFloat(parts[0]);
        const d=parseFloat(parts[1]);
        if(!isNaN(n)&&!isNaN(d)&&d!==0)return n/d;
      }
    }
    const x=parseFloat(str);
    return isNaN(x)?null:x;
  }

  function checkAnswer(){
    if(!currentQuestion)return;
    let isCorrect=false;
    let studentH,studentK;

    if(mode==="mc"){
      const chosen=document.querySelector('input[name="vertex"]:checked');
      if(!chosen){
        alert("Please select an answer first.");
        return;
      }
      const parts=chosen.value.split(",");
      studentH=parseFloat(parts[0]);
      studentK=parseFloat(parts[1]);
    }else{
      const hStr=inputHx.value;
      const kStr=inputKy.value;
      studentH=parseNumberInput(hStr);
      studentK=parseNumberInput(kStr);
      if(studentH===null||studentK===null){
        alert("Please enter numeric values for both h and k (fractions allowed).");
        return;
      }
    }

    const trueH=currentQuestion.h;
    const trueK=currentQuestion.k;

    const tol=(difficulty==="hard")?0.05:0.01;
    if(approxEqual(studentH,trueH,tol)&&approxEqual(studentK,trueK,tol)){
      isCorrect=true;
      score++;
      scoreDisplay.textContent=score;
    }

    const prettyH=roundNice(trueH);
    const prettyK=roundNice(trueK);

    feedbackDiv.style.display="block";
    if(isCorrect){
      feedbackDiv.className="feedback correct";
      feedbackDiv.innerHTML="Nice! ✅ The vertex is ("+prettyH+", "+prettyK+").";
    }else{
      feedbackDiv.className="feedback incorrect";
      feedbackDiv.innerHTML="Not quite. ❌ The correct vertex is ("+prettyH+", "+prettyK+").";
    }

    submitBtn.disabled=true;
    if(currentIndex<questions.length-1){
      nextBtn.style.display="inline-flex";
    }else{
      nextBtn.style.display="inline-flex";
      nextBtn.textContent="View summary";
    }
  }

  // ---------- Simple built‑in "AI" helper ----------
  function generateHint(q){
    const a=q.a,b=q.b,c=q.c;
    const hExact=-b/(2*a);
    const kExact=a*hExact*hExact+b*hExact+c;

    const pieces=[];
    pieces.push("Think of the formula for the x‑coordinate of the vertex: h = -b / (2a).");
    pieces.push("Here a = "+a+", b = "+b+", c = "+c+". So h = -("+b+") / (2·"+a+").");
    pieces.push("Once you have h, plug it back into y = ax² + bx + c to find k.");
    pieces.push("If arithmetic feels messy, estimate h first, then refine your value.");

    // Small meta comment based on difficulty
    if(difficulty==="easy"){
      pieces.push("On this level the vertex has nice integer coordinates. Use that to quickly check your work.");
    }else if(difficulty==="medium"){
      pieces.push("On this level the vertex still lands on integer coordinates, even if the steps look a bit scary.");
    }else{
      pieces.push("Here the vertex might be a fraction. Writing h as a simplified fraction can keep your calculations cleaner.");
    }

    // Very small "next‑step" suggestion using current input if any
    if(mode==="sa"){
      const tryH=parseNumberInput(inputHx.value||"");
      if(tryH!==null && !approxEqual(tryH,hExact,0.1)){
        pieces.push("Your current h guess is about "+roundNice(tryH)+". Compare it with -b/(2a) to nudge it closer.");
      }
    }

    return pieces.join(" ");
  }

  // ---------- LocalStorage scores ----------
  const STORAGE_KEY="mcr3u_vertex_scores_v1";
  function loadScores(){
    try{
      const raw=localStorage.getItem(STORAGE_KEY);
      if(!raw)return[];
      const data=JSON.parse(raw);
      return Array.isArray(data)?data:[];
    }catch(e){
      return[];
    }
  }
  function saveScoreEntry(entry){
    const scores=loadScores();
    scores.push(entry);
    // keep only last 15
    while(scores.length>15)scores.shift();
    localStorage.setItem(STORAGE_KEY,JSON.stringify(scores));
  }
  function renderScores(){
    const scores=loadScores();
    if(!scores.length){
      scoreboardContainer.style.display="none";
      return;
    }
    scoreboardContainer.style.display="block";
    scoreTableBody.innerHTML="";
    scores.slice().reverse().forEach(s=>{
      const tr=document.createElement("tr");
      tr.innerHTML="<td>"+s.timeStamp+"</td>"+
                   "<td>"+s.name+"</td>"+
                   "<td>"+s.className+"</td>"+
                   "<td>"+s.difficulty+"</td>"+
                   "<td>"+s.mode+"</td>"+
                   "<td>"+s.score+"/"+s.total+"</td>"+
                   "<td>"+formatTime(s.time)+"</td>";
      scoreTableBody.appendChild(tr);
    });
  }

  // ---------- Summary + "AI" comment ----------
  function showSummary(){
    quizCard.style.display="none";
    summaryCard.style.display="block";
    stopTimer();

    const name=studentNameInput.value.trim()||"Anonymous";
    const className=studentClassInput.value.trim()||"Unknown";
    const percent=Math.round((score/questions.length)*100);

    summaryText.textContent=name+" ("+className+") scored "+score+
      " out of "+questions.length+" in "+formatTime(elapsed)+
      " on "+difficulty+" difficulty ("+(mode==="mc"?"Multiple choice":"Short answer")+")";

    const commentParts=[];
    if(percent>=90){
      commentParts.push("This looks exam‑ready. The quadratics are probably more nervous than you are.");
    }else if(percent>=75){
      commentParts.push("Solid work. A few more sets at this level should make the vertex formula automatic.");
    }else if(percent>=50){
      commentParts.push("You understand the idea. Focus on slowing down with the algebra to reduce slips.");
    }else{
      commentParts.push("Use this as a diagnostic, not a verdict. Re‑watch notes/examples, then try again on easy or medium.");
    }

    if(elapsed/questions.length<20){
      commentParts.push("You are working quickly. Just check that speed is not costing you accuracy.");
    }else{
      commentParts.push("Your pace is careful. As you get more comfortable, try to nudge speed up a little.");
    }

    smartComment.textContent=commentParts.join(" ");

    const now=new Date();
    const stamp=now.toLocaleString();

    const entry={
      timeStamp:stamp,
      name:name,
      className:className,
      difficulty:difficulty,
      mode:(mode==="mc"?"MC":"SA"),
      score:score,
      total:questions.length,
      time:elapsed
    };
    try{
      saveScoreEntry(entry);
    }catch(e){
      // ignore storage issues (e.g., blocked in some environments)
    }
    renderScores();
  }

  // ---------- Event listeners ----------
  startBtn.addEventListener("click",()=>{
    const name=studentNameInput.value.trim();
    const className=studentClassInput.value.trim();
    if(!name||!className){
      alert("Please enter your name and class before starting.");
      return;
    }
    difficulty=difficultySelect.value;
    mode=modeSelect.value;
    numQuestions=parseInt(numQuestionsSelect.value,10);

    questions=generateQuestions(difficulty,numQuestions);
    currentIndex=0;
    score=0;
    displayName.textContent=name;
    displayClass.textContent=className;

    setupCard.style.display="none";
    summaryCard.style.display="none";
    quizCard.style.display="block";
    startTimer();
    showQuestion();
  });

  submitBtn.addEventListener("click",checkAnswer);

  nextBtn.addEventListener("click",()=>{
    if(currentIndex<questions.length-1){
      currentIndex++;
      showQuestion();
    }else{
      showSummary();
    }
  });

  aiHintBtn.addEventListener("click",()=>{
    if(!currentQuestion)return;
    aiHintDiv.style.display="block";
    aiHintDiv.textContent=generateHint(currentQuestion);
  });

  restartBtn.addEventListener("click",()=>{
    summaryCard.style.display="none";
    setupCard.style.display="block";
    nextBtn.textContent="Next question";
    renderScores();
  });

  resetScoresBtn.addEventListener("click",()=>{
    if(confirm("Clear all saved scores on this device?")){
      localStorage.removeItem(STORAGE_KEY);
      renderScores();
    }
  });

  // Load history on first load
  renderScores();
})();
</script>
